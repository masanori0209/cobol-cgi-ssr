<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8">
  <title>{{page_title}}</title>
  <style>
    body { font-family: sans-serif; max-width: 52rem; margin: 2rem auto; line-height: 1.6; }
    nav a { margin-right: 1rem; }
    nav a.active { font-weight: bold; text-decoration: none; color: #111; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ccc; padding: 0.4rem 0.6rem; text-align: left; }
    footer { margin-top: 2rem; color: #666; font-size: 0.9rem; }
  </style>
</head>
<body>
  <header>
    <h1>COBOL CGI SSR demo</h1>
    <nav>
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/posts">Posts</a>
      {{nav_user}}
    </nav>
  </header>
  <main>
    <h2>{{page_title}}</h2>
    {{page_body}}
  </main>
  <footer>GnuCOBOL + CGI — HTML generated on stdout per request.</footer>
</body>
</html>
